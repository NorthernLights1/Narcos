# Narcos on-prem deployment — copy to `.env` and fill in. NEVER commit .env.
# On the client box this file lives next to compose.yml (e.g. C:\narcos\.env).

# ---- required secrets ---------------------------------------------------
# 50+ random characters. Generate once; changing it just logs everyone out.
NARCOS_SECRET_KEY=change-me-to-a-long-random-string
# Strong PostgreSQL password. Set before the first `up` — it seeds the DB.
NARCOS_DB_PASSWORD=change-me-strong-db-password

# ---- LAN access ---------------------------------------------------------
# The static IP (and/or hostname) staff type in the browser. Comma-separated.
NARCOS_ALLOWED_HOSTS=192.168.1.50
# Usually leave blank: trusted origins are derived as http(s)://<each host>.
# Set explicitly only for unusual origins.
NARCOS_CSRF_TRUSTED_ORIGINS=
# Host port the app is published on (80 => plain http://<ip>).
NARCOS_HTTP_PORT=80

# ---- database (defaults are fine) ---------------------------------------
NARCOS_DB_NAME=narcos
NARCOS_DB_USER=narcos

# ---- backups ------------------------------------------------------------
# Windows host folder for nightly dumps; bind-mounted to /backups.
NARCOS_BACKUP_ROOT=C:\narcos\backups

# ---- image --------------------------------------------------------------
# Which image to run. `docker compose pull` fetches this tag.
NARCOS_IMAGE=ghcr.io/northernlights1/narcos:latest

# ---- advanced -----------------------------------------------------------
# 1 = app auto-applies migrations on start (default). 0 = apply manually.
NARCOS_AUTO_MIGRATE=1
# 1 = a TLS-terminating reverse proxy sits in front (enables secure cookies
# and X-Forwarded-Proto trust). Leave 0 for the plain-HTTP LAN deployment.
NARCOS_BEHIND_TLS_PROXY=0
